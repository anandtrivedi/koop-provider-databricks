# Databricks Connection Configuration
# Copy this file to .env and fill in your values

# Your Databricks personal access token
# Generate from: Databricks Console > User Settings > Access Tokens
DATABRICKS_TOKEN="your_personal_access_token_here"

# Your Databricks workspace hostname
# Format: <workspace-name>.<cloud-provider>.databricks.com
# Example: my-workspace.cloud.databricks.com
DATABRICKS_SERVER_HOSTNAME="your_workspace.cloud.databricks.com"

# HTTP path to your SQL warehouse OR general-purpose cluster
# Find in: SQL Warehouses > Configuration > Connection Details
#
# For SQL Warehouse:
# Format: /sql/1.0/warehouses/<warehouse-id>
DATABRICKS_HTTP_PATH="/sql/1.0/warehouses/your_warehouse_id"
#
# For General-Purpose Cluster:
# Format: sql/protocolv1/o/<org-id>/<cluster-id>
# DATABRICKS_HTTP_PATH="sql/protocolv1/o/your-org-id/your-cluster-id"

# Optional: Set log level (ERROR, WARN, INFO, DEBUG)
# Default: INFO
LOG_LEVEL="INFO"

# ============================================
# Authentication Configuration (Optional)
# ============================================

# Authentication mode: "disabled" or "enabled"
# - disabled: Uses environment variables above (no authentication required)
# - enabled: Uses API key authentication (requires config/auth.json)
# Default: disabled
AUTH_MODE="disabled"

# When AUTH_MODE=enabled:
# - Clients must obtain tokens from /databricks/tokens/ endpoint
# - Clients provide their API key to get a session token
# - Session tokens are passed via ?token=xxx query parameter
# - Configure API keys in config/auth.json (see config/auth.example.json)

# Token expiration time in seconds (when AUTH_MODE=enabled)
# Default: 3600 (1 hour)
TOKEN_EXPIRATION_SECONDS=3600

# Allow HTTP for token endpoints (for development only)
# Set to "true" to allow HTTP, omit or set to "false" for HTTPS only
# Default: false (HTTPS required)
# KOOP_AUTH_HTTP="false"

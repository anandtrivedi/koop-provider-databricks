# Databricks Connection Configuration
DATABRICKS_SERVER_HOSTNAME="your-workspace.cloud.databricks.com"
DATABRICKS_HTTP_PATH="/sql/1.0/warehouses/your-warehouse-id"
DATABRICKS_TOKEN="your-databricks-token"

# Optional Configuration
LOG_LEVEL="INFO"
SERVE_DEMO_PAGES="true"

# Authentication Configuration (Optional)
# Set to "enabled" to require API key authentication
# Set to "disabled" or omit to use environment variables only
AUTH_MODE="disabled"

# Token expiration in seconds (only used when AUTH_MODE=enabled)
TOKEN_EXPIRATION_SECONDS=3600

# Allow HTTP for token endpoints (development only)
# KOOP_AUTH_HTTP="false"
